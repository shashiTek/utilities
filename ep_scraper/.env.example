# =============================================================================
#  ep-scraper — Environment Configuration
# =============================================================================
#  Copy this file to .env and fill in your values.
#  .env is listed in .gitignore — never commit it.
# =============================================================================

# --- MongoDB -----------------------------------------------------------------
# Full MongoDB connection string.
# Local:    mongodb://localhost:27017/
# Atlas:    mongodb+srv://user:password@cluster.mongodb.net/
MONGO_URI=mongodb://nyxsvlalb697:27017/

# Database name
DB_NAME=elite_prospects_db

# --- Collection names (override if needed) -----------------------------------
LEAGUE_MEMBERS_COLLECTION=league_members
TEAMS_COLLECTION=teams
PLAYERS_COLLECTION=players
STATS_COLLECTION=stats

# --- Scraper targets ---------------------------------------------------------
# Which league slug to scrape from EliteProspects
# Examples: ushs-prep  ohl  qmjhl  whl  ncaa-d-i  ahl  liiga
EP_LEAGUE_SLUG=ushs-prep

# The calendar year that the season STARTS in  (2025 → season "2025-2026")
EP_TARGET_YEAR=2025

# --- HTTP behaviour ----------------------------------------------------------
# Seconds between requests — float ranges parsed as "min,max"
# e.g.  "1.5,3.0"  →  random.uniform(1.5, 3.0) per request
SCRAPE_DELAY_MIN=1.5
SCRAPE_DELAY_MAX=3.0

# Seconds to sleep after receiving a 403 rate-limit response (per retry)
RATE_LIMIT_BACKOFF=60

# Max retry attempts on network errors
MAX_RETRIES=3

# HTTP request timeout in seconds
REQUEST_TIMEOUT=30

# --- Logging -----------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to log file (leave blank to log to stdout only)
LOG_FILE=logs/ep_scraper.log
